use std::env;
use std::time::{SystemTime, UNIX_EPOCH};

fn json_escape(value: &str) -> String {
    value
        .replace('\\', "\\\\")
        .replace('"', "\\\"")
        .replace('\n', "\\n")
        .replace('\r', "\\r")
        .replace('\t', "\\t")
}

fn now_epoch_ms() -> u128 {
    SystemTime::now()
        .duration_since(UNIX_EPOCH)
        .unwrap_or_default()
        .as_millis()
}

fn main() {
    let environment = env::var("ENVIRONMENT").unwrap_or_else(|_| "development".to_string());
    let request_id = env::var("REQUEST_ID").ok();

    let mut json = String::from("{");
    json.push_str(&format!("\"timestamp\":{},", now_epoch_ms()));
    json.push_str("\"level\":\"INFO\",");
    json.push_str(&format!("\"service\":\"{}\",", json_escape("{{ project_slug }}")));
    json.push_str(&format!("\"environment\":\"{}\",", json_escape(&environment)));
    match request_id {
        Some(v) => json.push_str(&format!("\"request_id\":\"{}\",", json_escape(&v))),
        None => json.push_str("\"request_id\":null,"),
    }
    json.push_str("\"message\":\"Service started\",");
    json.push_str(&format!("\"version\":\"{}\"", json_escape("{{ project_version }}")));
    json.push_str("}");

    println!("{}", json);
}
