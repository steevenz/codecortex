@echo off
REM @project   {{ project_name }}
REM @category  Scripts/Setup
REM @author    {{ author }}
REM @copyright (c) {{ author }}
REM @fileoverview Development environment setup script (Windows Batch).
REM
REM Usage:
REM   scripts\setup\setup-dev-env.bat
REM   scripts\setup\setup-dev-env.bat --clean

setlocal enabledelayedexpansion

set PROJECT_NAME={{ project_name }}
set VENV_DIR=venv
set CLEAN=false

for %%a in (%*) do (
    if "%%a"=="--clean" set CLEAN=true
)

echo ============================================
echo   %PROJECT_NAME% — Development Setup
echo ============================================
echo.

if "%CLEAN%"=="true" (
    echo Cleaning existing venv...
    if exist "%VENV_DIR%" rmdir /s /q "%VENV_DIR%"
    echo    Done.
    echo.
)

if not exist "%VENV_DIR%" (
    echo Creating virtual environment...
    python -m venv %VENV_DIR%
    echo    Done.
) else (
    echo Virtual environment already exists.
)

echo Activating virtual environment...
call %VENV_DIR%\Scripts\activate.bat

echo Installing dependencies...
pip install --upgrade pip
pip install -e ".[dev]"
echo    Done.

echo.
echo ============================================
echo   Setup complete!
echo.
echo   Activate: %VENV_DIR%\Scripts\activate
echo   Run:      python -m src.main
echo   Test:     python -m pytest
echo ============================================

endlocal
