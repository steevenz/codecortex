# ===========================================================================
# {{ project_name }} — Environment Variables Template
# Copy this file to .env and fill in real values
# ===========================================================================

# Application
APP_NAME={{ project_name }}
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-to-a-secure-random-key

{% if stack_name == "python" %}
PYTHONPATH=src
{% endif %}
{% if project_type_id == "data_science" %}
# Data Science
DATA_PATH=datasets/
MODEL_PATH=outputs/results/models/
{% endif %}
{% if project_type_id == "web_api" %}
# Web API
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///db.sqlite3
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
JWT_SECRET_KEY=change-me-to-a-secure-random-key
{% endif %}
