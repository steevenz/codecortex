{
  "name": "codecortex",
  "version": "1.0.0",
  "description": "CodeCortex — Universal Code Intelligence Engine. Works with Claude, Cursor, Windsurf, Cline, and all MCP-compatible AI coders.",
  "main": "scripts/server/js/index.js",
  "bin": {
    "codecortex": "scripts/server/js/index.js",
    "codecortex-mcp": "scripts/server/js/index.js",
    "codecortex-cli": "scripts/cli.py"
  },
  "mcp": {
    "server": {
      "command": "node",
      "args": ["scripts/server/js/index.js"]
    },
    "stdio": {
      "command": "python",
      "args": ["-m", "src.main"]
    }
  },
  "scripts": {
    "start": "node scripts/server/js/index.js",
    "cli": "python scripts/cli.py",
    "mcp": "python -m src.main",
    "serve": "python -m scripts.server.http",
    "version": "python -c \"from src.core import load_version; print(load_version())\""
  },
  "keywords": [
    "mcp",
    "codecortex",
    "agentic",
    "architecture",
    "ai",
    "claude",
    "cursor",
    "windsurf",
    "cline"
  ],
  "author": "Aegis Codework / Steeven Andrian",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
