{
  "name": "codetester",
  "version": "0.1.0",
  "description": "Code tester domain — QA quality gate with 28 test framework adapters (pytest, jest, vitest, go test, cargo, maven, phpunit, xUnit, flutter test, and more)",
  "type": "module",
  "dependencies": {
    "modules": ["coderepository", "filesystem"],
    "core": ["config", "database", "errors", "logging", "telemetry"]
  },
  "providers": {
    "services": [
      "qa_service",
      "search_service"
    ],
    "adapters": [
      "pytest", "unittest", "jest", "vitest", "npm", "pnpm", "yarn",
      "go_test", "cargo_test", "kotlin_test", "maven_test", "sbt_test",
      "phpunit", "ruby_test", "elixir_test", "dart_test", "flutter_test",
      "swift_test", "haskell_test", "perl_test", "dotnet_test",
      "ctest", "stylelint", "flake8"
    ]
  },
  "tools": {
    "prefix": "code_tester",
    "entries": [
      "code_tester",
      "qa_status"
    ]
  },
  "test_adapters": 28,
  "author": {
    "name": "Steeven Andrian",
    "email": "steevenz@steevenz.com"
  },
  "copyright": "Copyright (c) 2026 Aegis Codework",
  "standard": "Aegis-CrossStack-v1.0"
}
