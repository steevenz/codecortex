{
  "name": "codegraph",
  "version": "0.1.0",
  "description": "Code graph domain — knowledge graph construction, query, relationship tracing, heritage extraction, route extraction, ORM dataflow, community detection, and architecture audit across 22 languages",
  "type": "module",
  "dependencies": {
    "modules": ["coderepository", "codeindex"],
    "core": ["config", "database", "errors", "graph", "logging", "telemetry", "token"]
  },
  "providers": {
    "services": [
      "codegraph_service",
      "aegis_builder",
      "community_leiden",
      "entry_point_scorer",
      "graph_audit",
      "graph_refactor",
      "graph_relationship",
      "graph_search",
      "graph_trace",
      "heritage_extractor",
      "orm_extractor",
      "process_detector",
      "route_extractor",
      "service_boundary"
    ],
    "graph_builders": [
      "office_worker",
      "persistence_writer"
    ]
  },
  "tools": {
    "prefix": "graph_",
    "entries": [
      "graph_build",
      "graph_query",
      "graph_find_symbols",
      "graph_find_related",
      "graph_trace_flow",
      "graph_find_patterns"
    ]
  },
  "relationships": [
    "calls",
    "imports",
    "inherits",
    "contains",
    "references"
  ],
  "graph_backends": ["kuzu", "neo4j", "falkordb", "supabase"],
  "author": {
    "name": "Steeven Andrian",
    "email": "steevenz@users.noreply.github.com"
  },
  "copyright": "Copyright (c) 2026 Aegis Codework",
  "standard": "Aegis-CrossStack-v1.0"
}
