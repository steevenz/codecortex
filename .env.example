# CodeCortex Configuration (Aegis v4.1)

# --- IDENTITY ---
CODECORTEX_IDENTITY=code-cortex-node-1

# --- MCP Server Configuration ---
CODECORTEX_TRANSPORT=stdio  # Options: stdio, sse
CODECORTEX_HOST=127.0.0.1
CODECORTEX_PORT=8001
CODECORTEX_MCP_SECRET=      # Optional: secure path suffix for SSE endpoint
CODECORTEX_CORS_ORIGINS=http://localhost,http://127.0.0.1

# --- AUTH (Shared Server Proxy) ---
CODECORTEX_BOOTSTRAP_API_KEY=         # Primary: bootstrap key for shared server auth
CODECORTEX_DASHBOARD_API_KEY=         # Legacy: fallback if bootstrap key not set
CODECORTEX_CLIENT_API_KEY=            # Auto-managed: issued client key (do not edit manually)
CODECORTEX_CLIENT_KEY_EXPIRES_AT=     # Auto-managed: key expiry timestamp
CODECORTEX_CLIENT_INSTANCE_ID=        # Auto-managed: instance identifier

# --- TLS (Optional) ---
CODECORTEX_CA_BUNDLE=                 # Path to custom CA bundle for HTTPS targets

# --- STORAGE ---
CODECORTEX_DB_PATH=database/codecortex.db
CODECORTEX_GRAPH_BACKEND=kuzu  # Options: kuzu, neo4j, falkordb, supabase

# --- SUPABASE (when CODECORTEX_GRAPH_BACKEND=supabase) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# --- BEHAVIOR ---
CODECORTEX_INCREMENTAL_FILE_THRESHOLD=2000
CODECORTEX_USE_UPSTREAM_CODEINDEX=0

# --- OBSERVABILITY ---
CODECORTEX_LOG_CONSOLE_FORMAT=json
CODECORTEX_LOG_STACKTRACE=0
LOG_LEVEL=INFO
