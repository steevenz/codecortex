# ===========================================================================
# Myawesomeproject — Environment Variables Template
# Copy this file to .env and fill in real values
# ===========================================================================

# Application
APP_NAME=Myawesomeproject
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-to-a-secure-random-key

PYTHONPATH=src
# Web API
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///db.sqlite3
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
JWT_SECRET_KEY=change-me-to-a-secure-random-key
